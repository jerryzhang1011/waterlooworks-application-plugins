# OS cruft
.DS_Store
**/.DS_Store

# Python build artifacts
__pycache__/
*.pyc

# ---------------------------------------------------------------------------
# Personal application data — NEVER commit. The plugin writes these into your
# own working directory while you use it; they contain your private details.
# ---------------------------------------------------------------------------
# Your real cover-letter header (only the example .json belongs in git)
coverletter-config.json
# resume/ and coverletter/ hold YOUR private files during normal use.
# Ignore everything inside them EXCEPT the example files shipped with this repo.
/resume/*
!/resume/example-resume.pdf
/coverletter/*
!/coverletter/example-coverletter.pdf
# Scraped job descriptions
/jds/
.tmp-jd-*.md
# Logged interactive answers
.codex_user_input_log.jsonl
